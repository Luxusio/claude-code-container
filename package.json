{
  "name": "claude-code-container",
  "version": "1.0.4",
  "description": "Run Claude Code in isolated Docker containers",
  "type": "module",
  "bin": {
    "ccc": "dist/index.js"
  },
  "files": [
    "dist/",
    "scripts/clipboard-shims/",
    "scripts/clipboard-helper-darwin.m",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const v=require('./package.json').version;const f='dist/utils.js';fs.writeFileSync(f,fs.readFileSync(f,'utf8').replace('__CLI_VERSION__',v))\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=14.14.0"
  },
  "keywords": [
    "claude",
    "container",
    "sandbox",
    "docker",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Luxusio/claude-code-container.git"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.0.0",
    "eslint-plugin-n": "^17.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.2"
  }
}
