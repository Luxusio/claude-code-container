{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for ccc desktop app",
  "local": true,
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:event:allow-emit-to",
    "core:event:allow-unlisten",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "ccc-daemon", "sidecar": true, "args": true }
      ]
    },
    "fs:default",
    "dialog:default",
    "notification:default"
  ]
}
