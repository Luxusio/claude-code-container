#!/bin/bash
# Start VNC server for viewing Chrome (used by ccc vnc)

# Start Xvfb if not running
if ! pgrep -x Xvfb >/dev/null; then
    Xvfb :99 -screen 0 1920x1080x24 &
    sleep 0.3
fi

# Start VNC server if not running
if ! pgrep -x x11vnc >/dev/null; then
    x11vnc -display :99 -forever -shared -nopw -rfbport 5900 2>/dev/null &
    echo "VNC server started: localhost:5900"
else
    echo "VNC server already running: localhost:5900"
fi
