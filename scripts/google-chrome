#!/bin/bash
# Chrome wrapper - auto-starts Xvfb when browser is launched

# Start Xvfb if not running
if ! pgrep -x Xvfb >/dev/null; then
    Xvfb :99 -screen 0 1920x1080x24 &
    sleep 0.3
fi

# Use Google Chrome (supports extensions)
exec /usr/bin/google-chrome-stable --no-sandbox --disable-gpu --no-first-run --disable-default-apps "$@"
